# ════════════════════════════════════════════════════════════════
# Andreu Logistics Backend — variables de entorno
# Copia este archivo a .env y llena los valores reales.
# ════════════════════════════════════════════════════════════════

# ── Postgres (Railway) ────────────────────────────────────
# Railway lo expone como ${{Postgres.DATABASE_URL}} en el panel
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:PUERTO/railway

# ── Auth ──────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_64_chars_random

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS / URLs ───────────────────────────────────────────
# Si tienes varios frontends, sepáralos con coma:
FRONTEND_URL=http://localhost:3000,https://andreu-logistics.up.railway.app
BACKEND_URL=http://localhost:4000

# ── Cron jobs ─────────────────────────────────────────────
ENABLE_CRON=false
CRON_TZ=America/Mexico_City

# ── Twilio (opcional, escalado alertas Autopilot) ────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DIRECTOR_WHATSAPP=whatsapp:+52XXXXXXXXXX

# ════════════════════════════════════════════════════════════════
# API Keys de Anthropic / Cloudinary se gestionan via BYOK desde
# la app (Configuración → API Keys) — NO las pongas aquí.
# ════════════════════════════════════════════════════════════════
